      "title": "Обзор API",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"irp_pet\"}[5m]))",
          "legendFormat": "HTTP req/s"
        }
      ],
      "title": "HTTP Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "targets": [
        { "expr": "irp_alerts_received_total", "legendFormat": "alerts" },
        { "expr": "irp_incidents_created_total", "legendFormat": "incidents" }
